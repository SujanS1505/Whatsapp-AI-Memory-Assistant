# AI Backend — Environment Variables
# Copy this file to .env and fill in the values

# ── AWS Bedrock ──────────────────────────────────────────────────────────────
# AWS IAM credentials with Bedrock access.
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=us-east-1

# Bedrock model IDs
# LLM for answer generation
BEDROCK_LLM_MODEL=mistral.mistral-7b-instruct-v0:2
# Embedding model
BEDROCK_EMBEDDING_MODEL=amazon.titan-embed-text-v2:0

# ── MongoDB ──────────────────────────────────────────────────────────────────
# MongoDB connection URI.
MONGODB_URI=mongodb://localhost:27017

# Name of the MongoDB database to use.
MONGODB_DB_NAME=whatsapp_ai

# Name of the messages collection inside MongoDB.
MESSAGES_COLLECTION=messages

# ── ChromaDB ─────────────────────────────────────────────────────────────────
# Local filesystem path where ChromaDB will persist vector data.
CHROMA_DB_PATH=./chroma_data

# Name of the ChromaDB collection.
CHROMA_COLLECTION_NAME=whatsapp_messages

# Number of top similar messages to retrieve per query.
TOP_K_RESULTS=10

# Maximum cosine distance allowed for a retrieved message to be treated as relevant.
# Lower values are stricter and will trigger general-knowledge fallback more often.
RETRIEVAL_MAX_DISTANCE=0.6

# ── Application ───────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
